# =============================================================================
# Client (homelab) — API + daemon + frontend + Redis (see docker-compose.client.yml)
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# App URL for OAuth redirect and CORS (must match the URL users open in the browser)
# Vite dev: http://localhost:5173 | docker-compose.client.yml: http://localhost:8080
APP_URL=http://localhost:5173

# Registry base URL (OAuth + role catalog). Local registry dev often :8001; production: https://registry.racksmith.io
REGISTRY_URL=http://localhost:8001

# Shared secret: set the SAME value on API and daemon in Compose (API → daemon HTTP + WS)
# Generate e.g. openssl rand -hex 32
# DAEMON_SECRET=

# API → daemon HTTP base URL (inside Compose the service is named daemon)
# DAEMON_URL=http://daemon:8001

# ── Optional (sensible defaults) ─────────────────────────────────────────────

# Workspace for cloned repos (Docker overrides via compose)
# REPOS_WORKSPACE=./workspace

# Data directory for SSH keys etc. (Docker overrides via compose)
# DATA_DIR=./data

# Redis URL (Docker overrides via compose)
# REDIS_URL=redis://localhost:6379

# Session (default: 7 days)
# SESSION_COOKIE_NAME=racksmith_session
# SESSION_MAX_AGE=604800

# Git commit author for Racksmith-created commits
# GIT_COMMIT_USER_NAME=Racksmith
# GIT_COMMIT_USER_EMAIL=racksmith@localhost

# SSH: disable host key verification in dev (default: true)
# SSH_DISABLE_HOST_KEY_CHECK=true

# Frontend dev server: API proxy target (Vite only, not used in Docker)
# VITE_API_TARGET=http://localhost:8000

# Production: image version tag (default: latest)
# RACKSMITH_VERSION=1.0.0

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# CORS: restrict allowed methods and headers (comma-separated, default: *)
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=content-type,authorization

# OpenAI for role generation (optional — generation features disabled without it)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Registry — what you (the operator) deploy in the cloud
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# GitHub OAuth App (create at github.com/settings/developers)
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Fernet encryption key for GH tokens at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Optional (sensible defaults) ─────────────────────────────────────────────

# Public URL of the registry (used as OAuth redirect_uri base)
# REGISTRY_PUBLIC_URL=http://localhost:8001

# Registry DB password (required for docker-compose.prod)
# REGISTRY_DB_PASSWORD=your_secure_password

# Database connection string (default uses local dev credentials)
# DATABASE_URL=postgresql+asyncpg://registry:registry@localhost:5432/registry

# CORS origins allowed to call the registry (comma-separated)
# ALLOWED_ORIGINS=http://localhost:5173

# CORS methods/headers (comma-separated, default: *)
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=content-type,authorization

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
